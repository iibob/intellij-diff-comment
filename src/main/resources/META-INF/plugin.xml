<idea-plugin>
    <id>com.github.iibob.diffcomment</id>
    <name>Diff Comment Helper</name>
    <vendor>iibob</vendor>
    <vendor url="https://github.com/iibob">iibob</vendor>
    <description>
        <![CDATA[
        Enables code commenting and proper indentation directly in Diff views launched via command line.
        <br><br>
        专为独立差异模式设计：即使不启动完整 IDE，仅通过命令行对比文件时，也能在差异视图中启用代码注释及缩进功能。
        ]]>
    </description>
    <change-notes>
        <![CDATA[
    <ul>
        <li>V1.1.0: Added support for Tab and Shift+Tab indentation in Diff views.</li>
        <li>V1.1.0: 增加了对差异视图中 Tab 和 Shift+Tab 缩进功能的支持。</li>
    </ul>
    ]]>
    </change-notes>
    <depends>com.intellij.modules.platform</depends>
    <actions>
        <action id="com.github.iibob.diffcomment.ToggleComment"
                class="com.github.iibob.diffcomment.DiffCommentAction"
                text="Toggle Comment">
            <add-to-group group-id="Diff.EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="control SLASH"/>
        </action>

        <action id="com.github.iibob.diffcomment.Indent"
                class="com.github.iibob.diffcomment.DiffIndentAction"
                text="Indent">
            <add-to-group group-id="Diff.EditorPopupMenu" anchor="last"/>
<!--            <keyboard-shortcut keymap="$default" first-keystroke="control CLOSE_BRACKET"/>-->
            <keyboard-shortcut keymap="$default" first-keystroke="TAB"/>
        </action>

        <action id="com.github.iibob.diffcomment.Unindent"
                class="com.github.iibob.diffcomment.DiffUnindentAction"
                text="Unindent">
            <add-to-group group-id="Diff.EditorPopupMenu" anchor="last"/>
<!--            <keyboard-shortcut keymap="$default" first-keystroke="control OPEN_BRACKET"/>-->
            <keyboard-shortcut keymap="$default" first-keystroke="shift TAB"/>
        </action>
    </actions>
</idea-plugin>